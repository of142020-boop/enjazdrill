---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - الصفحة غير موجودة | إنجاز دريل">
  <section style="min-height:100vh; display:flex; align-items:center; justify-content:center; background:var(--dark); padding-top:80px;">
    <div class="container" style="text-align:center;">
      <div style="font-size:80px; margin-bottom:24px;">🔩</div>
      <h1 style="font-size:clamp(60px,10vw,120px); font-weight:900; color:var(--primary); line-height:1; margin-bottom:16px;">404</h1>
      <h2 style="font-size:24px; font-weight:700; color:var(--white); margin-bottom:16px;">الصفحة غير موجودة</h2>
      <p style="color:var(--text-muted); font-size:16px; margin-bottom:36px; max-width:500px; margin-left:auto; margin-right:auto; line-height:1.8;">
        يبدو أن الصفحة التي تبحث عنها غير موجودة أو تم نقلها. عُد إلى الصفحة الرئيسية أو تواصل معنا مباشرة.
      </p>
      <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
        <a href="/" class="btn btn-primary">← العودة للرئيسية</a>
        <a href="tel:+201029834485" class="btn btn-accent">📞 اتصل بنا</a>
      </div>
    </div>
  </section>
</Layout>
