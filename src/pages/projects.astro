---
import Layout from '../layouts/Layout.astro';

const projectImages1 = [
  { src: '/images/image-1.webp', alt: 'قص خرسانة' },
  { src: '/images/6.webp', alt: 'تخريم خرسانة' },
  { src: '/images/1.webp', alt: 'فتحات كور' },
  { src: '/images/11.webp', alt: 'فتحات كور في أكتوبر' },
  { src: '/images/10.webp', alt: 'أعمال التخريم' },
];
const projectImages2 = [
  { src: '/images/منشار.webp', alt: 'منشار قص الخرسانة' },
  { src: '/images/image-1.webp', alt: 'قص خرسانة' },
  { src: '/images/outdoor-image-04.webp', alt: 'تخريم خارجي' },
  { src: '/images/outdoor-image-01.webp', alt: 'أعمال خارجية' },
];
const projectImages3 = [
  { src: '/images/8.webp', alt: 'تشطيبات' },
  { src: '/images/7.webp', alt: 'تشطيبات خرسانة' },
  { src: '/images/snow-1.webp', alt: 'أعمال التأسيس' },
  { src: '/images/5.webp', alt: 'معدات التخريم' },
];
---
<Layout title="معرض الأعمال | إنجاز دريل لقص وتخريم الخرسانة" description="شاهد أعمال إنجاز دريل في قص وتخريم الخرسانة في مصر" canonical="https://enjazdrill.com/projects/" navbarStyle="solid">

  <section class="page-hero">
    <h1>معرض أعمال إنجاز دريل<br/>لقص وتخريم الخرسانة</h1>
  </section>

  <section class="page-content">
    
    <!-- Gallery 1: Core Drilling Projects -->
    <div class="gallery-section">
      <h2 class="section-title">أعمال تخريم الكور</h2>
      <div class="gallery-grid">
        {projectImages1.map(img => (
          <div class="gallery-item">
            <img src={img.src} alt={img.alt} loading="lazy" />
          </div>
        ))}
      </div>
    </div>

    <!-- Gallery 2: Architectural Modifications -->
    <div class="gallery-section">
      <div class="section-label">خدمات التعديلات المعمارية</div>
      <div class="gallery-grid">
        {projectImages2.map(img => (
          <div class="gallery-item">
            <img src={img.src} alt={img.alt} loading="lazy" />
          </div>
        ))}
      </div>
    </div>

    <!-- Gallery 3: Finishing Works -->
    <div class="gallery-section">
      <div class="section-label">تجهيزات التشطيبات والتأسيس</div>
      <div class="gallery-grid">
        {projectImages3.map(img => (
          <div class="gallery-item">
            <img src={img.src} alt={img.alt} loading="lazy" />
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div style="text-align:center;margin-top:60px;padding:40px;background:var(--bg-hero);border-radius:12px;">
      <h2 style="color:white;font-size:26px;margin-bottom:20px;">هل تريد تنفيذ مشروعك؟</h2>
      <a href="tel:+201029834485" class="btn-primary">اتصل بنا الآن: 01029834485</a>
    </div>

  </section>
</Layout>

<style>
.page-hero {
  background-color: var(--bg-hero);
  padding: 180px 20px 80px;
  text-align: center;
  color: white;
}
.page-hero h1 { font-size: clamp(24px, 3.5vw, 46px); font-weight: 800; line-height: 1.3; }
.page-content { max-width: 1200px; margin: 0 auto; padding: 60px 20px; }
.gallery-section { margin-bottom: 60px; }
.section-title { font-size: 28px; font-weight: 800; margin-bottom: 30px; text-align: center; }
.section-label {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-dark);
  border-right: 4px solid var(--primary-pink);
  padding-right: 16px;
  margin-bottom: 24px;
}
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 16px;
}
.gallery-item {
  border-radius: 8px;
  overflow: hidden;
  aspect-ratio: 1;
}
.gallery-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s;
}
.gallery-item img:hover { transform: scale(1.05); }
</style>
